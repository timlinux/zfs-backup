# Maintainer: Kartoza <info@kartoza.com>
pkgname=zfs-backup
pkgver=1.2.0
pkgrel=1
pkgdesc="Beautiful TUI for managing ZFS backups"
arch=('x86_64' 'aarch64')
url="https://github.com/timlinux/zfs-backup"
license=('MIT')
depends=('zfs-utils' 'sanoid')
optdepends=('udisks2: for USB drive power management')
makedepends=('go')
source=("$pkgname-$pkgver.tar.gz::https://github.com/timlinux/zfs-backup/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$pkgname-$pkgver"
    export CGO_ENABLED=0
    go build -ldflags="-s -w -X main.appVersion=$pkgver" -o "$pkgname" .
}

package() {
    cd "$pkgname-$pkgver"
    install -Dm755 "$pkgname" "$pkgdir/usr/bin/$pkgname"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
